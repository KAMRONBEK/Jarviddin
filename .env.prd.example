# Production (VPS) — copy to server `.env` or import into Doppler `prd` config.
# Webhook mode: HTTPS reverse proxy, PUBLIC_BASE_URL, setWebhook, TELEGRAM_WEBHOOK_SECRET.

NODE_ENV=production
PORT=3000

# Do not set LOCAL_DEV in production.
# LOCAL_DEV=false

TELEGRAM_USE_POLLING=false

# Public HTTPS base (no trailing slash) — used for logs and Telegram setWebhook URL.
PUBLIC_BASE_URL=https://your-domain.com

# --- Telegram (@BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=

# --- Cursor Cloud / Background Agents API ---
CURSOR_API_KEY=
CURSOR_API_BASE=https://api.cursor.com
DEFAULT_GITHUB_REPO=https://github.com/your-org/your-repo
DEFAULT_GIT_REF=main

CURSOR_MAX_CONCURRENT_AGENTS=2
CURSOR_POLL_INTERVAL_MS=15000
CURSOR_POLL_MAX_MINUTES=120

SQLITE_PATH=./data/orchestrator.db
# DATABASE_URL=postgres://user:pass@db:5432/jarviddin

# Optional: Trello REST fallback
# TRELLO_KEY=
# TRELLO_TOKEN=
# TRELLO_DEFAULT_LIST_ID=

# Optional: GitHub REST (/mergepr)
# GITHUB_TOKEN=
# GITHUB_DEFAULT_OWNER=
# GITHUB_DEFAULT_REPO=

# Optional: NullClaw webhook
# NULLCLAW_WEBHOOK_URL=

# Optional: comma-separated phrases for merge-to-main hint (default: merge to main)
# AGENT_MERGE_MAIN_KEYWORD=

# Optional: DeepSeek gate before /agent
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_CLARIFY_ROUNDS=3
