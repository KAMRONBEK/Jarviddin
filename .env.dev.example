# Development (laptop) — copy to .env or import into Doppler `dev` config.
# Long polling: no HTTPS, domain, setWebhook, or TELEGRAM_WEBHOOK_SECRET required.

# --- Core dev flags ---
NODE_ENV=development
PORT=3000
LOCAL_DEV=true
TELEGRAM_USE_POLLING=true

# Optional; not needed while polling (leave empty or omit).
PUBLIC_BASE_URL=

# --- Telegram (@BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789

# Webhook mode only — skip when TELEGRAM_USE_POLLING=true
# TELEGRAM_WEBHOOK_SECRET=

# --- Cursor (optional at startup with LOCAL_DEV; required for /agent) ---
CURSOR_API_KEY=
CURSOR_API_BASE=https://api.cursor.com
DEFAULT_GITHUB_REPO=https://github.com/your-org/your-repo
DEFAULT_GIT_REF=main

CURSOR_MAX_CONCURRENT_AGENTS=2
CURSOR_POLL_INTERVAL_MS=15000
CURSOR_POLL_MAX_MINUTES=120

SQLITE_PATH=./data/orchestrator.db
# DATABASE_URL=postgres://user:pass@localhost:5432/jarviddin

# Optional: Trello / GitHub / NullClaw / DeepSeek — same as production when you need them.
# TRELLO_KEY=
# TRELLO_TOKEN=
# TRELLO_DEFAULT_LIST_ID=
# GITHUB_TOKEN=
# GITHUB_DEFAULT_OWNER=
# GITHUB_DEFAULT_REPO=
# NULLCLAW_WEBHOOK_URL=
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_CLARIFY_ROUNDS=3
